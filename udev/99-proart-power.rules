# Fire the controller on every AC plug/unplug. The oneshot reads the actual
# power state + override, so both edges trigger the same apply.
SUBSYSTEM=="power_supply", ATTR{type}=="Mains", ATTR{online}=="0", RUN+="/usr/bin/systemctl --no-block start proart-power.service"
SUBSYSTEM=="power_supply", ATTR{type}=="Mains", ATTR{online}=="1", RUN+="/usr/bin/systemctl --no-block start proart-power.service"
